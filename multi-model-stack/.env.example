# Copy to .env and tweak. All keys are optional — defaults work on a single
# 24 GB+ NVIDIA GPU. Defaults below are the "small server" preset.

# ── LLM (served as "qwen3.6" via LiteLLM) ─────────────────────────────────
# Default: Qwen3-8B (~16 GB on disk, fits in a 24 GB GPU).
# Big-server preset: Qwen/Qwen3.6-35B-A3B-FP8 (~38 GB, needs 80 GB+ GPU).
LLM_MODEL=Qwen/Qwen3-8B
LLM_GPU_UTIL=0.55
LLM_MAX_LEN=32768
LLM_MAX_SEQS=32

# ── Embeddings (served as "qwen3-embedding") ─────────────────────────────
# Default: Qwen3-Embedding-8B (~16 GB).
# Lite preset: Qwen/Qwen3-Embedding-0.6B (~1.2 GB).
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_GPU_UTIL=0.20
EMBED_MAX_LEN=8192

# ── Whisper (served as "whisper") ────────────────────────────────────────
# Default: large-v3. Smaller options:
#   Systran/faster-whisper-medium  (~1.5 GB)
#   Systran/faster-whisper-small   (~500 MB)
WHISPER_MODEL=Systran/faster-whisper-large-v3

# ── Infra knobs ──────────────────────────────────────────────────────────
VLLM_IMAGE=vllm/vllm-openai:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-class-demo

# Admin UI credentials (login at http://<host>:4000/ui)
UI_USERNAME=admin
UI_PASSWORD=sk-class-demo

# GPU device index ("0" = first GPU; "0,1" for multi-GPU; "all" to expose all).
NVIDIA_VISIBLE_DEVICES=0

# Set this for cutting-edge GPUs whose arch is newer than your vLLM image's
# default. Examples:
#   Blackwell (RTX PRO 6000, B100): "12.0+PTX"
#   Hopper    (H100, H200):         "9.0+PTX"
# Leave empty on Ada/Ampere/Lovelace — vLLM picks the right kernels.
TORCH_CUDA_ARCH_LIST=

# Needed only for gated/private HF repos. Generate at https://huggingface.co/settings/tokens
HF_TOKEN=
